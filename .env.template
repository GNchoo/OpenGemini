# OpenGemini Environment Variables Template

# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (numeric)
ALLOWED_USER_ID=your_numeric_user_id_here

# Engines Configuration
# Local path to gemini-cli binary
GEMINI_BIN=/home/username/.npm-global/bin/gemini
# Local path to claude-code binary
CLAUDE_BIN=/usr/local/bin/claude

# Default Settings
DEFAULT_ENGINE=gemini
GEMINI_MODEL_DEFAULT=gemini-2.0-flash-exp
GEMINI_APPROVAL_MODE=yolo
GEMINI_SANDBOX=false

# Workspace and Context
GEMINI_WORKDIR=./workspace
GEMINI_INCLUDE_DIRS=./projects,./tools

# Optional: GitHub Token for broader tool access
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Optional: Gemini API Key (if not using OAuth)
# GEMINI_API_KEY=your_gemini_api_key_here
